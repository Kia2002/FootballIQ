# Copy this file to .env and fill in real values.
# Never commit .env — it is gitignored.

# PostgreSQL connection string
POSTGRES_CONNECTION_STRING=Host=localhost;Port=5432;Database=footballiq;Username=postgres;Password=postgres

# football-data.org API key (free tier at football-data.org)
FOOTBALLDATA_API_KEY=your_api_key_here

# Path to the cloned StatsBomb open-data "data" folder (see CLAUDE.md StatsBomb Data Reference)
STATSBOMB_DATA_ROOT=data/statsbomb/data

# LLM provider: ollama | azureopenai | openai
LLM_PROVIDER=ollama

# --- Ollama (local development, free) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.2

# --- Azure OpenAI (production) ---
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=your_key_here
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# --- OpenAI API (alternative to Azure) ---
OPENAI_API_KEY=your_key_here

# Embedding vector dimensions — must match the model you use
# nomic-embed-text (Ollama): 768
# text-embedding-3-small (OpenAI): 1536
EMBEDDING_DIMENSIONS=768
